# ═══════════════════════════════════════════════════════════════════════════════
# .env.example — Trading RAG Mentor
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# NEVER commit .env to version control — it is gitignored.
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM Provider ────────────────────────────────────────────────────────────────
# Sets the default provider shown in the sidebar on first load.
# Options: "Groq (Fast Cloud)" | "Ollama (Local & Private)"
# LLM_PROVIDER=Groq (Fast Cloud)

# ── Groq (required when LLM_PROVIDER=Groq) ──────────────────────────────────────
# Groq API key — free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Default Groq model shown in the sidebar (can be changed at runtime)
# GROQ_MODEL_NAME=openai/gpt-oss-120b

# ── Ollama (required when LLM_PROVIDER=Ollama) ─────────────────────────────────
# Base URL of your local Ollama server (default shown below)
# OLLAMA_BASE_URL=http://localhost:11434

# Default Ollama model tag (must be pulled first with `ollama pull <model>`)
# Options: gpt-oss:120b-cloud | gemma3:1b
# OLLAMA_MODEL=gpt-oss:120b-cloud

# ── Optional path overrides ───────────────────────────────────────────────────────
# Defaults shown — only set these if you have changed the project layout.
# CHROMA_DB_PATH=data/chroma_db
# TRANSCRIPTS_PATH=data/transcripts
# CHAT_HISTORY_DB=data/chat_history.db
